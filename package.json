{
  "name": "neo-lj-archive",
  "version": "0.1.0",
  "description": "Archive a LiveJournal — entries, threaded comments, and local copies of every image — into a static site you can read offline, forever, without this tool.",
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "type-check": "tsc --noEmit && tsc -p tsconfig.test.json",
    "type-check:tests": "tsc -p tsconfig.test.json",
    "test:run": "vitest run"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "commander": "^15.0.0",
    "ejs": "^6.0.1",
    "fast-xml-parser": "^5.10.1",
    "parse5": "^8.0.1",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/ejs": "^3.1.5",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "bin": {
    "neo-lj": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=22.13"
  }
}
